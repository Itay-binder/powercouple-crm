# --- Google Sheets (Service Account) ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}
GOOGLE_SPREADSHEET_ID=...
# אופציונלי (לייבוא עתידי / לא נחוץ ל-MVP הנוכחי כי הלידים נקלטים ישירות ל-CRM)
GOOGLE_SHEET_RANGE='Leads'!A:Z

# --- Firebase Admin (Service Account JSON from Firebase Console) ---
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# אופציונלי: שם bucket ל-Storage (העלאת מסמכים לפתקים). ברירת מחדל: bucket ברירת המחדל של הפרויקט.
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# --- Firebase Client (Web SDK snippet) ---
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
NEXT_PUBLIC_FIREBASE_PROJECT_ID=...
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=...
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
NEXT_PUBLIC_FIREBASE_APP_ID=...

# --- Access control ---
# optional: admins always allowed
ADMIN_EMAILS=you@gmail.com

# session cookie lifespan in days (1-14), default: 5
SESSION_MAX_AGE_DAYS=7

# iframe / third-party cookie support (optional)
SESSION_COOKIE_CROSS_SITE=true

# auth disabled for local dev only (optional)
# AUTH_DISABLED=true

# --- CRM Ingestion (Make -> CRM API) ---
# מפתח סודי גלובלי (אופציונלי אם יוצרים מפתחות מהגדרות → API במסד הנוכחי).
# נשלח בכותרת x-api-key / x-crm-api-key / Authorization: Bearer
CRM_INGEST_API_KEY=your-secret-key-here

# מיגרציה חד־פעמית: העברת מזהה מסמך leads (איש קשר) לפי הטלפון המנורמל בשדה phone.
# ב-Vercel: CONTACT_MIGRATE_SECRET + POST /api/internal/migrate-contact-doc-id (Bearer או body.secret).
# מקומית: npm run migrate:contact-phone -- --dry-run --match-name "שם מלא"
# או GitHub Actions: workflow "Migrate contact doc id to phone" (secret: FIREBASE_SERVICE_ACCOUNT_JSON)
# CONTACT_MIGRATE_SECRET=long-random-string

# מסדי Firestore (databaseId) שמותר להם קליטה עם תאריכי יצירה/עדכון היסטוריים (contact-upsert / opportunity-upsert).
# ללא המשתנה — התאריכים מהגוף יתעלמו. דוגמה: powercouple,client-x-db
# CRM_HISTORICAL_IMPORT_TENANT_DATABASE_IDS=powercouple

# אופציונלי: אם לפרויקט יש כמה Firestore Databases, אפשר לקבע איזה DB השרת משתמש בו.
# דוגמאות: (default) / liftygo-crm / liftygo-crmdb
# FIRESTORE_DATABASE_ID=(default)

# --- ריבוי עסקים (multi-tenant) ---
# רשימת עסקים ב-JSON. לכל עסק: id (מזהה מערכת), databaseId (שם מסד ב-Firestore), label (לייבל בממשק),
# seedDefaultPipeline (ברירת מחדל true; false = CRM נקי בלי פייפליין ברירת מחדל),
# members (רשימת מיילים עם גישה לעסק הספציפי; מנהלים ב-ADMIN_EMAILS נכנסים לכולם).
# CRM_DEFAULT_TENANT_ID — איזה עסק נטען למשתמש בלי עוגיית tenant (ברירת מחדל: הפריט הראשון ברשימה).
#
# CRM_TENANTS=[
#   {"id":"liftygo-customers","databaseId":"liftygo-crmdb","label":"לקוחות","seedDefaultPipeline":true},
#   {"id":"liftygo-leads","databaseId":"liftygo-leads","label":"לידים","seedDefaultPipeline":false,"members":["a@x.com","b@y.com"]}
# ]
# CRM_DEFAULT_TENANT_ID=liftygo-customers
#
# טננטים שבהם מוצג "ניהול הזמנות" בתפריט וניתן לקלוט mover-welcome / moving-order (מופריד בפסיק).
# אם לא מוגדר: liftygo-customers,default — כדי שטננט ברירת מחדל (id=default) לא ייחסם.
# CRM_MOVING_ORDERS_TENANT_IDS=liftygo-customers
#
# מזהה מסמך פייפליין ב-Firestore ל«לקוחות משלמים» (התאמת מובילים). אם לא מוגדר — ניסיון אוטומטי לפי שם הפייפליין.
# CRM_PAYING_CUSTOMERS_PIPELINE_ID=customers
#
# אינטגרציות (Make): לנתיבי /api/leads ו-/api/ingest אפשר לשלוח כותרת
# x-crm-tenant-database-id=<databaseId> או x-crm-tenant=<id> כדי לכוון למסד הנכון.

# --- Google Calendar (OAuth — משימות CRM → אירועים בלוח) ---
# ב-Google Cloud Console: OAuth 2.0 Client (Web), Redirect URI = <APP_URL>/api/google-calendar/callback
# Scopes: calendar.events, calendar.readonly, userinfo.email, openid
# GOOGLE_CALENDAR_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=...
# מומלץ: כתובת האפליקציה לצורך callback (או הגדרו GOOGLE_CALENDAR_REDIRECT_URI במפורש)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/api/google-calendar/callback

# --- Web Push (התראות למכשיר גם כשהדפדפן סגור — VAPID) ---
# יצירת מפתחות: npx web-push generate-vapid-keys
# Public חייב להיות זהה בשרת ובקליינט (NEXT_PUBLIC). Private רק בשרת.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BN...
# VAPID_PRIVATE_KEY=...
# אופציונלי (ברירת מחדל mailto:noreply@liftygo.local)
# VAPID_SUBJECT=mailto:support@yourdomain.com

# --- Meta WhatsApp Business (אוטומציות ווצאפ) ---
# ברירת מחדל ל-Graph API. אופציונלי; אפשר להשאיר כך.
# WHATSAPP_GRAPH_API_BASE=https://graph.facebook.com/v22.0
# אימות Webhook נכנס ממטא (GET /api/whatsapp/webhook)
# חשוב: זה מחרוזת סודית שאתם ממציאים (וב-meta שמים אותה ב-Verify token) — לא כתובת ה-URL של ה-webhook.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-secure-random-token
# אם ה-CRM על מסד Firestore לא-(default) (למשל CRM_TENANTS): חובה ש-webhook ממטא יכתוב לאותו מסד.
# WHATSAPP_WEBHOOK_FIRESTORE_DATABASE_ID=your-database-id

# --- GREENAPI (ווצאפ דרך Green API) ---
# ברירת מחדל לשרת Green API. אופציונלי — ניתן גם להגדיר במסך GREENAPI במערכת.
# GREENAPI_API_BASE=https://api.green-api.com

# --- Canva Connect (יצירת קמפיינים עם עיצובי Canva) ---
# צור App ב: https://www.canva.com/developers/
# הגדר Redirect URI: <APP_URL>/api/meta-ads/canva/callback
# Scopes: design:content:read, design:meta:read
CANVA_CLIENT_ID=your-canva-client-id
CANVA_CLIENT_SECRET=your-canva-client-secret

# --- Meta Ads Manager ---
# יצירת App ב: https://developers.facebook.com → My Apps → Create App → Business
# הוסף את ה-product "Marketing API" לאפליקציה.
# הגדר Redirect URI: <APP_URL>/api/meta-ads/callback (תחת App Settings → Valid OAuth Redirect URIs)
#
# Meta App ID (נראה ב-App Dashboard — ציבורי)
META_APP_ID=your-meta-app-id
#
# Meta App Secret (נראה ב-App Dashboard → App Secret — סודי, רק בשרת)
META_APP_SECRET=your-meta-app-secret
#
# כתובת האפליקציה — חייב להיות מוגדר לצורך OAuth callback
# NEXT_PUBLIC_APP_URL=https://your-domain.com
#
# ברירת מחדל ל-Graph API (אופציונלי)
# META_GRAPH_API_BASE=https://graph.facebook.com/v22.0

# אופציונלי: סדר סטייג'ים כמו ב-GHL
CRM_STAGE_ORDER=Pending,Contacted,Won,Lost

# --- סוכן SEO ---
# הקשר עסקי גלובלי (אופציונלי) — JSON עם name + blurb או טקסט חופשי
# CRM_SEO_BUSINESS_CONTEXT={"name":"העסק","blurb":"..."}
# שליפת טקסט מכתובת האתר בהגדרות SEO (ברירת מחדל: מופעל). לכיבוי:
# SEO_AGENT_FETCH_SITE=false

# --- פרסום מאמרי SEO לוורדפרס (REST + Application Password) ---
# כתובת בסיס של ה-REST API (כולל /wp-json)
# WORDPRESS_REST_BASE=https://example.com/wp-json
# משתמש וורדפרס + סיסמת אפליקציה (ללא רווחים בסיסמה — אפשר להדביק עם רווחים, השרת מנקה)
# WORDPRESS_USERNAME=admin
# WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

